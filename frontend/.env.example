# Public Supabase config (safe to commit placeholders; real values in .env.local which is gitignored)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME

# Backend URL (this Next.js app calls the Go API on the VPS)
NEXT_PUBLIC_API_URL=http://localhost:8080
