# Backend env (root-level for clarity). Copy to backend/.env and fill in real values.
# Real .env files are gitignored. NEVER commit secrets.

# Database
DATABASE_URL=postgres://postgres.PROJECT_REF:CHANGE_ME@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Alternative direct (IPv6 only — works on VPS, not on most local networks):
# postgres://postgres:CHANGE_ME@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# Server
PORT=8080
ENV=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,https://lumio.id

# Supabase (server-side only — never expose to FE)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
SUPABASE_JWT_SECRET=CHANGE_ME
